              "shortDescription": {
                "text": "README.md has no quickstart section"
              },
              "fullDescription": {
                "text": "The README is missing a section agents commonly need to orient themselves."
              },
              "help": {
                "text": "Add a quickstart that gets a new user to a working command quickly.",
                "markdown": "Add a quickstart that gets a new user to a working command quickly."
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "properties": {
