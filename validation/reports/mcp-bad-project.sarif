            {
              "id": "mcp.detected",
              "name": "MCP-related files or packages detected",
              "shortDescription": {
                "text": "MCP-related files or packages detected"
              },
              "fullDescription": {
                "text": "MCP signals were found and can be evaluated by future deeper analyzers."
              },
              "help": {
                "text": "Ensure each MCP tool has a clear name, description, input schema, and safety guidance.",
                "markdown": "Ensure each MCP tool has a clear name, description, input schema, and safety guidance."
              },
              "defaultConfiguration": {
                "level": "note"
              },
              "properties": {
                "category": "mcp_tools",
                "severity": "info",
                "tags": ["agent-readiness", "mcp_tools", "info"]
              }
            },
            {
              "id": "security.missing-agentlighthouseignore",
              "name": "Missing .agentlighthouseignore",
              "shortDescription": {
                "text": "Missing .agentlighthouseignore"
              },
              "fullDescription": {
                "text": "Scans should explicitly exclude generated, private, and secret-bearing paths."
              },
              "help": {
                "text": "Add .agentlighthouseignore with node_modules, build outputs, env files, secrets, and vendor paths.",
                "markdown": "Add .agentlighthouseignore with node_modules, build outputs, env files, secrets, and vendor paths."
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "properties": {
                "category": "security_and_privacy",
                "severity": "medium",
                "tags": ["agent-readiness", "security_and_privacy", "medium"]
              }
            },
            {
              "id": "security.agent-secret-guidance-missing",
              "name": "Instructions do not tell agents how to handle secrets",
              "shortDescription": {
                "text": "Instructions do not tell agents how to handle secrets"
              },
              "fullDescription": {
                "text": "Agent-facing instructions should state how to avoid exposing secrets or private data."
              },
              "help": {
                "text": "Add a security section explaining secret handling and external LLM constraints.",
                "markdown": "Add a security section explaining secret handling and external LLM constraints."
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "properties": {
                "category": "security_and_privacy",
                "severity": "medium",
                "tags": ["agent-readiness", "security_and_privacy", "medium"]
              }
            },
            {
              "id": "freshness.deprecated-or-todo-terms",
              "name": "Docs contain TODO/deprecated-looking terms without migration guidance",
              "shortDescription": {
                "text": "Docs contain TODO/deprecated-looking terms without migration guidance"
              },
              "fullDescription": {
                "text": "Stale markers can confuse agents unless they include replacement guidance."
              },
              "help": {
                "text": "Resolve TODOs or add explicit migration/replacement guidance.",
                "markdown": "Resolve TODOs or add explicit migration/replacement guidance."
              },
              "defaultConfiguration": {
                "level": "note"
              },
              "properties": {
                "category": "freshness_and_consistency",
                "severity": "low",
                "tags": ["agent-readiness", "freshness_and_consistency", "low"]
              }
            },
            {
              "id": "MCP_TOOL_NAME_AMBIGUOUS",
              "name": "MCP tool names are ambiguous",
              "shortDescription": {
                "text": "MCP tool names are ambiguous"
              },
              "fullDescription": {
                "text": "2 MCP tool(s) need stronger agent-facing metadata."
              },
              "help": {
                "text": "Rename generic tools so the action and resource are obvious.",
                "markdown": "Rename generic tools so the action and resource are obvious.\n\nAgent failure mode: A coding agent may choose a generic tool like run or query for the wrong workflow.\n\nFix example: Use names such as search_docs, create_workspace_ticket, or revoke_api_key."
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "properties": {
                "category": "mcp_tools",
                "severity": "medium",
                "tags": ["agent-readiness", "mcp_tools", "medium"]
              }
            },
            {
              "id": "MCP_TOOL_DESCRIPTION_SHALLOW",
              "name": "MCP tool descriptions are too shallow",
              "shortDescription": {
                "text": "MCP tool descriptions are too shallow"
              },
              "fullDescription": {
                "text": "2 MCP tool(s) need stronger agent-facing metadata."
              },
              "help": {
                "text": "Expand tool descriptions with intent, constraints, and safe usage guidance.",
                "markdown": "Expand tool descriptions with intent, constraints, and safe usage guidance.\n\nAgent failure mode: A coding agent may not distinguish similar tools without usage context.\n\nFix example: Mention input expectations, side effects, auth requirements, and error behavior."
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "properties": {
                "category": "mcp_tools",
                "severity": "medium",
                "tags": ["agent-readiness", "mcp_tools", "medium"]
              }
            },
            {
              "id": "MCP_TOOL_INPUT_SCHEMA_MISSING",
              "name": "MCP tools are missing input schemas",
              "shortDescription": {
                "text": "MCP tools are missing input schemas"
              },
              "fullDescription": {
                "text": "2 MCP tool(s) need stronger agent-facing metadata."
              },
              "help": {
                "text": "Add structured input schemas with required fields and descriptions.",
                "markdown": "Add structured input schemas with required fields and descriptions.\n\nAgent failure mode: A coding agent may pass malformed arguments or omit required identifiers.\n\nFix example: Use a zod/object schema with workspace_id and query fields plus descriptions."
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "properties": {
                "category": "mcp_tools",
                "severity": "high",
                "tags": ["agent-readiness", "mcp_tools", "high"]
              }
            },
            {
              "id": "MCP_TOOL_EXAMPLE_MISSING",
              "name": "MCP tools lack examples or usage notes",
              "shortDescription": {
                "text": "MCP tools lack examples or usage notes"
              },
              "fullDescription": {
                "text": "2 MCP tool(s) need stronger agent-facing metadata."
              },
              "help": {
                "text": "Add examples or usage notes for common calls.",
                "markdown": "Add examples or usage notes for common calls.\n\nAgent failure mode: A coding agent may not know the expected argument shape or output semantics.\n\nFix example: Include an example invocation showing realistic placeholder arguments."
              },
              "defaultConfiguration": {
                "level": "note"
              },
              "properties": {
                "category": "mcp_tools",
                "severity": "low",
                "tags": ["agent-readiness", "mcp_tools", "low"]
              }
            },
            {
              "id": "MCP_TOOL_DESTRUCTIVE_ACTION_UNMARKED",
              "name": "Destructive MCP tools are not clearly marked",
              "shortDescription": {
                "text": "Destructive MCP tools are not clearly marked"
              },
              "fullDescription": {
                "text": "1 MCP tool(s) need stronger agent-facing metadata."
              },
              "help": {
                "text": "Mark destructive tools and document confirmation, permissions, and safe testing behavior.",
                "markdown": "Mark destructive tools and document confirmation, permissions, and safe testing behavior.\n\nAgent failure mode: A coding agent may call a write/delete tool without realizing it changes external state.\n\nFix example: State that the tool mutates data and requires explicit user approval outside test fixtures."
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "properties": {
                "category": "mcp_tools",
                "severity": "high",
                "tags": ["agent-readiness", "mcp_tools", "high"]
              }
            },
            {
              "id": "MCP_TOOL_ERROR_BEHAVIOR_UNCLEAR",
              "name": "MCP tool error behavior is unclear",
              "shortDescription": {
                "text": "MCP tool error behavior is unclear"
              },
              "fullDescription": {
                "text": "2 MCP tool(s) need stronger agent-facing metadata."
              },
              "help": {
                "text": "Explain common errors and whether retry or user follow-up is appropriate.",
                "markdown": "Explain common errors and whether retry or user follow-up is appropriate.\n\nAgent failure mode: A coding agent may retry unsafe operations or fail silently when a tool returns an error.\n\nFix example: Document not-found, unauthorized, rate-limit, and validation failures."
              },
              "defaultConfiguration": {
                "level": "note"
              },
              "properties": {
                "category": "mcp_tools",
                "severity": "low",
                "tags": ["agent-readiness", "mcp_tools", "low"]
              }
            },
            {
              "id": "TASK_BENCHMARK_MISSING",
              "name": "Missing agent task benchmark file",
              "shortDescription": {
                "text": "Missing agent task benchmark file"
              },
              "fullDescription": {
                "text": "The project has no agentlighthouse.tasks.yaml or benchmark task file."
              },
              "help": {
                "text": "Add agentlighthouse.tasks.yaml with realistic, verifiable agent workflows.",
                "markdown": "Add agentlighthouse.tasks.yaml with realistic, verifiable agent workflows.\n\nAgent failure mode: A team cannot tell whether agents can complete common workflows because no deterministic task set exists.\n\nFix example: Add tasks for installing the project, running tests, adding a small feature, and using the public API."
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "properties": {
                "category": "task_benchmarks",
                "severity": "medium",
                "tags": ["agent-readiness", "task_benchmarks", "medium"]
              }
            },
            {
              "id": "COMMAND_VERIFICATION_SKIPPED",
              "name": "Command verification probes were skipped",
              "shortDescription": {
                "text": "Command verification probes were skipped"
              },
              "fullDescription": {
                "text": "Static analysis is default; project commands are not executed unless explicitly enabled."
              },
              "help": {
                "text": "Use command probes in trusted local or CI environments when you want executable verification.",
                "markdown": "Use command probes in trusted local or CI environments when you want executable verification.\n\nAgent failure mode: Without command probes, AgentLighthouse can tell agents what commands appear to exist, but not whether they currently pass.\n\nFix example: agentlighthouse scan . --probe commands"
              },
              "defaultConfiguration": {
                "level": "note"
              },
              "properties": {
                "category": "setup_and_tests",
                "severity": "info",
                "tags": ["agent-readiness", "setup_and_tests", "info"]
              }
            }
          ]
        }
