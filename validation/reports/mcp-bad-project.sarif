            {
              "id": "api.openapi-not-detected",
              "name": "OpenAPI file not detected",
              "shortDescription": {
                "text": "OpenAPI file not detected"
              },
              "fullDescription": {
                "text": "No OpenAPI schema was found. This may be fine for projects without an HTTP API."
              },
              "help": {
