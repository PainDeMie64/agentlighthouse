{
  "version": "2.1.0",
  "$schema": "https://json.schemastore.org/sarif-2.1.0.json",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "AgentLighthouse",
          "semanticVersion": "0.1.0-alpha.0",
          "informationUri": "https://github.com/PainDeMie64/agentlighthouse",
          "rules": [
            {
              "id": "agent-instructions.claude-vague",
              "name": "CLAUDE.md appears stale or too vague",
              "shortDescription": {
                "text": "CLAUDE.md appears stale or too vague"
              },
              "fullDescription": {
                "text": "CLAUDE.md exists but may not contain enough stable project memory."
              },
              "help": {
                "text": "Refresh CLAUDE.md with current setup commands, product boundaries, and test expectations.",
                "markdown": "Refresh CLAUDE.md with current setup commands, product boundaries, and test expectations."
              },
              "defaultConfiguration": {
                "level": "note"
              },
              "properties": {
                "category": "agent_instructions",
                "severity": "low",
                "tags": ["agent-readiness", "agent_instructions", "low"]
              }
            },
            {
              "id": "api.openapi-not-detected",
              "name": "OpenAPI file not detected",
              "shortDescription": {
                "text": "OpenAPI file not detected"
              },
              "fullDescription": {
                "text": "No OpenAPI schema was found. This may be fine for projects without an HTTP API."
              },
              "help": {
                "text": "For API products, publish an OpenAPI spec with operation descriptions and examples.",
                "markdown": "For API products, publish an OpenAPI spec with operation descriptions and examples."
              },
              "defaultConfiguration": {
                "level": "note"
              },
              "properties": {
                "category": "api_schema",
                "severity": "info",
                "tags": ["agent-readiness", "api_schema", "info"]
              }
            },
            {
              "id": "mcp.detected",
              "name": "MCP-related files or packages detected",
              "shortDescription": {
                "text": "MCP-related files or packages detected"
              },
              "fullDescription": {
                "text": "MCP signals were found and can be evaluated by future deeper analyzers."
              },
              "help": {
                "text": "Ensure each MCP tool has a clear name, description, input schema, and safety guidance.",
                "markdown": "Ensure each MCP tool has a clear name, description, input schema, and safety guidance."
              },
              "defaultConfiguration": {
                "level": "note"
              },
              "properties": {
                "category": "mcp_tools",
                "severity": "info",
                "tags": ["agent-readiness", "mcp_tools", "info"]
              }
            },
            {
              "id": "COMMAND_VERIFICATION_SKIPPED",
              "name": "Command verification probes were skipped",
              "shortDescription": {
                "text": "Command verification probes were skipped"
              },
              "fullDescription": {
                "text": "Static analysis is default; project commands are not executed unless explicitly enabled."
              },
              "help": {
                "text": "Use command probes in trusted local or CI environments when you want executable verification.",
                "markdown": "Use command probes in trusted local or CI environments when you want executable verification.\n\nAgent failure mode: Without command probes, AgentLighthouse can tell agents what commands appear to exist, but not whether they currently pass.\n\nFix example: agentlighthouse scan . --probe commands"
              },
              "defaultConfiguration": {
                "level": "note"
              },
              "properties": {
                "category": "setup_and_tests",
                "severity": "info",
                "tags": ["agent-readiness", "setup_and_tests", "info"]
              }
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "agent-instructions.claude-vague",
          "level": "note",
          "message": {
            "text": "CLAUDE.md appears stale or too vague: Refresh CLAUDE.md with current setup commands, product boundaries, and test expectations."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "CLAUDE.md"
                },
                "region": {
                  "startLine": 1
                }
              }
            }
          ],
          "partialFingerprints": {
            "agentLighthouseFinding": "alh_d545fec5"
          },
          "properties": {
            "category": "agent_instructions",
            "severity": "low",
            "recommendation": "Refresh CLAUDE.md with current setup commands, product boundaries, and test expectations.",
            "confidence": "medium",
            "subject": "CLAUDE.md",
            "locationKey": "claude.md",
            "sourceKind": "markdown"
          }
        },
        {
          "ruleId": "api.openapi-not-detected",
          "level": "note",
          "message": {
            "text": "OpenAPI file not detected: For API products, publish an OpenAPI spec with operation descriptions and examples."
          },
          "partialFingerprints": {
            "agentLighthouseFinding": "alh_64a67cea"
          },
          "properties": {
            "category": "api_schema",
            "severity": "info",
            "recommendation": "For API products, publish an OpenAPI spec with operation descriptions and examples.",
            "confidence": "medium",
            "subject": "No openapi.* or swagger.* file was scanned.",
            "locationKey": "no openapi.* or swagger.* file was scanned."
          }
        },
        {
          "ruleId": "mcp.detected",
          "level": "note",
          "message": {
            "text": "MCP-related files or packages detected: Ensure each MCP tool has a clear name, description, input schema, and safety guidance."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "src/mcp-server.example.txt"
                },
                "region": {
                  "startLine": 1
                }
              }
            }
          ],
          "partialFingerprints": {
            "agentLighthouseFinding": "alh_0a35bf27"
          },
          "properties": {
            "category": "mcp_tools",
            "severity": "info",
            "recommendation": "Ensure each MCP tool has a clear name, description, input schema, and safety guidance.",
            "confidence": "medium",
            "subject": "src/mcp-server.example.txt",
            "locationKey": "src/mcp-server.example.txt",
            "sourceKind": "unknown"
          }
        },
        {
          "ruleId": "COMMAND_VERIFICATION_SKIPPED",
          "level": "note",
          "message": {
            "text": "Command verification probes were skipped: Use command probes in trusted local or CI environments when you want executable verification."
          },
          "partialFingerprints": {
            "agentLighthouseFinding": "alh_ac2d574f"
          },
          "properties": {
            "category": "setup_and_tests",
            "severity": "info",
            "agentFailureMode": "Without command probes, AgentLighthouse can tell agents what commands appear to exist, but not whether they currently pass.",
            "recommendation": "Use command probes in trusted local or CI environments when you want executable verification.",
            "fixExample": "agentlighthouse scan . --probe commands",
            "confidence": "medium",
            "subject": "Run with --probe commands or --run-probes to execute safe script probes.",
            "locationKey": "run with --probe commands or --run-probes to execute safe script probes."
          }
        }
      ]
    }
  ]
}
