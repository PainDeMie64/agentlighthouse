{
  "version": "2.1.0",
  "$schema": "https://json.schemastore.org/sarif-2.1.0.json",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "AgentLighthouse",
          "semanticVersion": "0.1.0",
          "informationUri": "https://github.com/PainDeMie64/agentlighthouse",
          "rules": [
            {
              "id": "api.openapi-not-detected",
              "name": "OpenAPI file not detected",
              "shortDescription": {
                "text": "OpenAPI file not detected"
              },
              "fullDescription": {
                "text": "No OpenAPI schema was found. This may be fine for projects without an HTTP API."
              },
              "help": {
                "text": "For API products, publish an OpenAPI spec with operation descriptions and examples.",
                "markdown": "For API products, publish an OpenAPI spec with operation descriptions and examples."
              },
              "defaultConfiguration": {
                "level": "note"
              },
              "properties": {
                "category": "api_schema",
                "severity": "info",
                "tags": ["agent-readiness", "api_schema", "info"]
              }
            },
            {
              "id": "mcp.not-evaluated",
              "name": "MCP readiness could not be evaluated yet",
              "shortDescription": {
                "text": "MCP readiness could not be evaluated yet"
              },
              "fullDescription": {
                "text": "No MCP server/config/package signal was detected."
              },
              "help": {
                "text": "If this project exposes MCP tools, include server files and clear tool descriptions.",
                "markdown": "If this project exposes MCP tools, include server files and clear tool descriptions."
              },
              "defaultConfiguration": {
                "level": "note"
              },
              "properties": {
                "category": "mcp_tools",
                "severity": "info",
                "tags": ["agent-readiness", "mcp_tools", "info"]
              }
            },
            {
              "id": "freshness.deprecated-or-todo-terms",
              "name": "Docs contain TODO/deprecated-looking terms without migration guidance",
              "shortDescription": {
                "text": "Docs contain TODO/deprecated-looking terms without migration guidance"
              },
              "fullDescription": {
                "text": "Stale markers can confuse agents unless they include replacement guidance."
              },
              "help": {
                "text": "Resolve TODOs or add explicit migration/replacement guidance.",
                "markdown": "Resolve TODOs or add explicit migration/replacement guidance."
              },
              "defaultConfiguration": {
                "level": "note"
              },
              "properties": {
                "category": "freshness_and_consistency",
                "severity": "low",
                "tags": ["agent-readiness", "freshness_and_consistency", "low"]
              }
            },
            {
              "id": "COMMAND_VERIFICATION_SKIPPED",
              "name": "Command verification probes were skipped",
              "shortDescription": {
                "text": "Command verification probes were skipped"
              },
              "fullDescription": {
                "text": "Static analysis is default; project commands are not executed unless explicitly enabled."
              },
              "help": {
                "text": "Use command probes in trusted local or CI environments when you want executable verification.",
                "markdown": "Use command probes in trusted local or CI environments when you want executable verification.\n\nAgent failure mode: Without command probes, AgentLighthouse can tell agents what commands appear to exist, but not whether they currently pass.\n\nFix example: agentlighthouse scan . --probe commands"
              },
              "defaultConfiguration": {
                "level": "note"
              },
              "properties": {
                "category": "setup_and_tests",
                "severity": "info",
                "tags": ["agent-readiness", "setup_and_tests", "info"]
              }
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "api.openapi-not-detected",
          "level": "note",
          "message": {
            "text": "OpenAPI file not detected: For API products, publish an OpenAPI spec with operation descriptions and examples."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "No openapi.* or swagger.* file was scanned."
                },
                "region": {
                  "startLine": 1
                }
              }
            }
          ],
          "partialFingerprints": {
            "agentLighthouseFinding": "alh_64a67cea"
          },
          "properties": {
            "category": "api_schema",
            "severity": "info",
            "recommendation": "For API products, publish an OpenAPI spec with operation descriptions and examples.",
            "confidence": "medium",
            "subject": "No openapi.* or swagger.* file was scanned.",
            "locationKey": "no openapi.* or swagger.* file was scanned.",
            "sourceKind": "openapi"
          }
        },
        {
          "ruleId": "mcp.not-evaluated",
          "level": "note",
          "message": {
            "text": "MCP readiness could not be evaluated yet: If this project exposes MCP tools, include server files and clear tool descriptions."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "No file or package name matching MCP was scanned."
                },
                "region": {
                  "startLine": 1
                }
              }
            }
          ],
          "partialFingerprints": {
            "agentLighthouseFinding": "alh_0a02b750"
          },
          "properties": {
            "category": "mcp_tools",
            "severity": "info",
            "recommendation": "If this project exposes MCP tools, include server files and clear tool descriptions.",
            "confidence": "medium",
            "subject": "No file or package name matching MCP was scanned.",
            "locationKey": "no file or package name matching mcp was scanned.",
            "sourceKind": "unknown"
          }
        },
        {
          "ruleId": "freshness.deprecated-or-todo-terms",
          "level": "note",
          "message": {
            "text": "Docs contain TODO/deprecated-looking terms without migration guidance: Resolve TODOs or add explicit migration/replacement guidance."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "docs/PR_AWARE_ANALYSIS.md"
                },
                "region": {
                  "startLine": 1
                }
              }
            }
          ],
          "partialFingerprints": {
            "agentLighthouseFinding": "alh_803cbab6"
          },
          "properties": {
            "category": "freshness_and_consistency",
            "severity": "low",
            "recommendation": "Resolve TODOs or add explicit migration/replacement guidance.",
            "confidence": "medium",
            "subject": "docs/PR_AWARE_ANALYSIS.md:69: - `related`: the finding is linked through a location key, old path, or source file.",
            "locationKey": "docs/pr_aware_analysis.md:69: - `related`: the finding is linked through a location key, old path, or source file.",
            "sourceKind": "markdown"
          }
        },
        {
          "ruleId": "COMMAND_VERIFICATION_SKIPPED",
          "level": "note",
          "message": {
            "text": "Command verification probes were skipped: Use command probes in trusted local or CI environments when you want executable verification."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "Run with --probe commands or --run-probes to execute safe script probes."
                },
                "region": {
                  "startLine": 1
                }
              }
            }
          ],
          "partialFingerprints": {
            "agentLighthouseFinding": "alh_ac2d574f"
          },
          "properties": {
            "category": "setup_and_tests",
            "severity": "info",
            "agentFailureMode": "Without command probes, AgentLighthouse can tell agents what commands appear to exist, but not whether they currently pass.",
            "recommendation": "Use command probes in trusted local or CI environments when you want executable verification.",
            "fixExample": "agentlighthouse scan . --probe commands",
            "confidence": "medium",
            "subject": "Run with --probe commands or --run-probes to execute safe script probes.",
            "locationKey": "run with --probe commands or --run-probes to execute safe script probes.",
            "sourceKind": "unknown"
          }
        }
      ]
    }
  ]
}
