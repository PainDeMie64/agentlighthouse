{
  "version": "2.1.0",
  "$schema": "https://json.schemastore.org/sarif-2.1.0.json",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "AgentLighthouse",
          "semanticVersion": "0.1.0",
          "informationUri": "https://github.com/PainDeMie64/agentlighthouse",
          "rules": [
            {
              "id": "agent-instructions.missing-agents-md",
              "name": "Missing AGENTS.md",
              "shortDescription": {
                "text": "Missing AGENTS.md"
              },
              "fullDescription": {
                "text": "The repo has no AGENTS.md, so coding agents lack a stable project guide."
              },
              "help": {
                "text": "Create AGENTS.md with setup, tests, architecture, conventions, and safety rules.",
                "markdown": "Create AGENTS.md with setup, tests, architecture, conventions, and safety rules."
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "properties": {
                "category": "agent_instructions",
                "severity": "high",
                "tags": ["agent-readiness", "agent_instructions", "high"]
              }
            },
            {
              "id": "agent-instructions.missing-claude-md",
              "name": "Missing CLAUDE.md",
              "shortDescription": {
                "text": "Missing CLAUDE.md"
              },
              "fullDescription": {
                "text": "Claude Code users do not have a concise project memory file."
              },
              "help": {
                "text": "Add CLAUDE.md with concise workflow, boundaries, and testing expectations.",
                "markdown": "Add CLAUDE.md with concise workflow, boundaries, and testing expectations."
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "properties": {
                "category": "agent_instructions",
                "severity": "medium",
                "tags": ["agent-readiness", "agent_instructions", "medium"]
              }
            },
            {
              "id": "artifact-quality.READMEmd.missing-clear-test-command",
              "name": "README.md exists, but does not include clear test command",
              "shortDescription": {
                "text": "README.md exists, but does not include clear test command"
              },
              "fullDescription": {
                "text": "A detected agent-facing artifact is missing specific guidance agents need for reliable work."
              },
              "help": {
                "text": "Add clear test command to README.md.",
                "markdown": "Add clear test command to README.md."
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "properties": {
                "category": "agent_instructions",
                "severity": "medium",
                "tags": ["agent-readiness", "agent_instructions", "medium"]
              }
            },
            {
              "id": "artifact-quality.READMEmd.missing-architecture-or-repo-map",
              "name": "README.md exists, but does not include architecture or repo map",
              "shortDescription": {
                "text": "README.md exists, but does not include architecture or repo map"
              },
              "fullDescription": {
                "text": "A detected agent-facing artifact is missing specific guidance agents need for reliable work."
              },
              "help": {
                "text": "Add architecture or repo map to README.md.",
                "markdown": "Add architecture or repo map to README.md."
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "properties": {
                "category": "agent_instructions",
                "severity": "medium",
                "tags": ["agent-readiness", "agent_instructions", "medium"]
              }
            },
            {
              "id": "artifact-quality.readme-missing-verification-step",
              "name": "README has installation guidance but no verification step",
              "shortDescription": {
                "text": "README has installation guidance but no verification step"
              },
              "fullDescription": {
                "text": "Agents need a quick command to verify the project works after installation."
              },
              "help": {
                "text": "Add a short verification step such as running tests, typecheck, build, or a health command.",
                "markdown": "Add a short verification step such as running tests, typecheck, build, or a health command."
              },
              "defaultConfiguration": {
                "level": "note"
              },
              "properties": {
                "category": "documentation",
                "severity": "low",
                "tags": ["agent-readiness", "documentation", "low"]
              }
            },
            {
              "id": "artifact-quality.readme-commands-not-grounded-in-scripts",
              "name": "README commands are not clearly grounded in package.json scripts",
              "shortDescription": {
                "text": "README commands are not clearly grounded in package.json scripts"
              },
              "fullDescription": {
                "text": "Commands are more trustworthy when README examples match executable project scripts."
              },
              "help": {
                "text": "Show package-manager commands that map directly to package.json scripts.",
                "markdown": "Show package-manager commands that map directly to package.json scripts."
              },
              "defaultConfiguration": {
                "level": "note"
              },
              "properties": {
                "category": "freshness_and_consistency",
                "severity": "low",
                "tags": ["agent-readiness", "freshness_and_consistency", "low"]
              }
            },
            {
              "id": "artifact-quality.readme-missing-troubleshooting",
              "name": "README lacks troubleshooting guidance",
              "shortDescription": {
                "text": "README lacks troubleshooting guidance"
              },
              "fullDescription": {
                "text": "Developer-tool and API projects benefit from troubleshooting notes because agents often need to recover from local setup failures."
              },
              "help": {
                "text": "Add a short troubleshooting section with common setup and test failure fixes.",
                "markdown": "Add a short troubleshooting section with common setup and test failure fixes."
              },
              "defaultConfiguration": {
                "level": "note"
              },
              "properties": {
                "category": "documentation",
                "severity": "low",
                "tags": ["agent-readiness", "documentation", "low"]
              }
            },
            {
              "id": "llms.missing",
              "name": "Missing llms.txt",
              "shortDescription": {
                "text": "Missing llms.txt"
              },
              "fullDescription": {
                "text": "The project does not expose a compact, machine-readable map for LLMs and agents."
              },
              "help": {
                "text": "Create llms.txt with links to README, docs, architecture, examples, and API references.",
                "markdown": "Create llms.txt with links to README, docs, architecture, examples, and API references."
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "properties": {
                "category": "agent_instructions",
                "severity": "medium",
                "tags": ["agent-readiness", "agent_instructions", "medium"]
              }
            },
            {
              "id": "docs.readme-no-quickstart",
              "name": "README.md has no quickstart section",
              "shortDescription": {
                "text": "README.md has no quickstart section"
              },
              "fullDescription": {
                "text": "The README is missing a section agents commonly need to orient themselves."
              },
              "help": {
                "text": "Add a quickstart that gets a new user to a working command quickly.",
                "markdown": "Add a quickstart that gets a new user to a working command quickly."
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "properties": {
                "category": "documentation",
                "severity": "medium",
                "tags": ["agent-readiness", "documentation", "medium"]
              }
            },
            {
              "id": "docs.readme-no-install",
              "name": "README.md has no installation instructions",
              "shortDescription": {
                "text": "README.md has no installation instructions"
              },
              "fullDescription": {
                "text": "The README is missing a section agents commonly need to orient themselves."
              },
              "help": {
                "text": "Add installation commands and prerequisites.",
                "markdown": "Add installation commands and prerequisites."
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "properties": {
                "category": "documentation",
                "severity": "medium",
                "tags": ["agent-readiness", "documentation", "medium"]
              }
            },
            {
              "id": "docs.readme-no-examples",
              "name": "README.md has no examples",
              "shortDescription": {
                "text": "README.md has no examples"
              },
              "fullDescription": {
                "text": "The README is missing a section agents commonly need to orient themselves."
              },
              "help": {
                "text": "Add concrete examples showing expected usage and output.",
                "markdown": "Add concrete examples showing expected usage and output."
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "properties": {
                "category": "documentation",
                "severity": "medium",
                "tags": ["agent-readiness", "documentation", "medium"]
              }
            },
            {
              "id": "docs.directory-missing",
              "name": "Docs directory missing",
              "shortDescription": {
                "text": "Docs directory missing"
              },
              "fullDescription": {
                "text": "No docs directory was detected for deeper project context."
              },
              "help": {
                "text": "Add docs/ for architecture, development, API, and operational context.",
                "markdown": "Add docs/ for architecture, development, API, and operational context."
              },
              "defaultConfiguration": {
                "level": "note"
              },
              "properties": {
                "category": "documentation",
                "severity": "low",
                "tags": ["agent-readiness", "documentation", "low"]
              }
            },
            {
              "id": "setup.package-json-no-scripts",
              "name": "package.json has no scripts",
              "shortDescription": {
                "text": "package.json has no scripts"
              },
              "fullDescription": {
                "text": "Agents cannot discover standard local workflows from package.json."
              },
              "help": {
                "text": "Add scripts for test, lint, typecheck, build, and local development.",
                "markdown": "Add scripts for test, lint, typecheck, build, and local development."
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "properties": {
                "category": "setup_and_tests",
                "severity": "high",
                "tags": ["agent-readiness", "setup_and_tests", "high"]
              }
            },
            {
              "id": "setup.missing-test-script",
              "name": "No test script in package.json",
              "shortDescription": {
                "text": "No test script in package.json"
              },
              "fullDescription": {
                "text": "Agents cannot reliably run test without a package script."
              },
              "help": {
                "text": "Add a package.json \"test\" script or document the equivalent command clearly.",
                "markdown": "Add a package.json \"test\" script or document the equivalent command clearly."
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "properties": {
                "category": "setup_and_tests",
                "severity": "high",
                "tags": ["agent-readiness", "setup_and_tests", "high"]
              }
            },
            {
              "id": "setup.missing-lint-script",
              "name": "No lint script in package.json",
              "shortDescription": {
                "text": "No lint script in package.json"
              },
              "fullDescription": {
                "text": "Agents cannot reliably run lint without a package script."
              },
              "help": {
                "text": "Add a package.json \"lint\" script or document the equivalent command clearly.",
                "markdown": "Add a package.json \"lint\" script or document the equivalent command clearly."
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "properties": {
                "category": "setup_and_tests",
                "severity": "medium",
                "tags": ["agent-readiness", "setup_and_tests", "medium"]
              }
            },
            {
              "id": "setup.missing-typecheck-script",
              "name": "No typecheck script in package.json",
              "shortDescription": {
                "text": "No typecheck script in package.json"
              },
              "fullDescription": {
                "text": "Agents cannot reliably run typecheck without a package script."
              },
              "help": {
                "text": "Add a package.json \"typecheck\" script or document the equivalent command clearly.",
                "markdown": "Add a package.json \"typecheck\" script or document the equivalent command clearly."
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "properties": {
                "category": "setup_and_tests",
                "severity": "medium",
                "tags": ["agent-readiness", "setup_and_tests", "medium"]
              }
            },
            {
              "id": "api.openapi-detected",
              "name": "OpenAPI file detected",
              "shortDescription": {
                "text": "OpenAPI file detected"
              },
              "fullDescription": {
                "text": "The scanner found an API schema that agents can use."
              },
              "help": {
                "text": "Keep API descriptions, examples, and auth details current.",
                "markdown": "Keep API descriptions, examples, and auth details current."
              },
              "defaultConfiguration": {
                "level": "note"
              },
              "properties": {
                "category": "api_schema",
                "severity": "info",
                "tags": ["agent-readiness", "api_schema", "info"]
              }
            },
            {
              "id": "api.openapi-no-nearby-examples",
              "name": "OpenAPI exists but no examples are nearby",
              "shortDescription": {
                "text": "OpenAPI exists but no examples are nearby"
              },
              "fullDescription": {
                "text": "Agents need request and response examples in addition to schemas."
              },
              "help": {
                "text": "Add examples near the API spec or link examples from the API documentation.",
                "markdown": "Add examples near the API spec or link examples from the API documentation."
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "properties": {
                "category": "api_schema",
                "severity": "medium",
                "tags": ["agent-readiness", "api_schema", "medium"]
              }
            },
            {
              "id": "api.openapi-thin-descriptions",
              "name": "OpenAPI operation descriptions appear thin",
              "shortDescription": {
                "text": "OpenAPI operation descriptions appear thin"
              },
              "fullDescription": {
                "text": "The OpenAPI schema may not provide enough semantic guidance for agents."
              },
              "help": {
                "text": "Add meaningful operation descriptions, auth notes, and representative examples.",
                "markdown": "Add meaningful operation descriptions, auth notes, and representative examples."
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "properties": {
                "category": "api_schema",
                "severity": "medium",
                "tags": ["agent-readiness", "api_schema", "medium"]
              }
            },
            {
              "id": "mcp.not-evaluated",
              "name": "MCP readiness could not be evaluated yet",
              "shortDescription": {
                "text": "MCP readiness could not be evaluated yet"
              },
              "fullDescription": {
                "text": "No MCP server/config/package signal was detected."
              },
              "help": {
                "text": "If this project exposes MCP tools, include server files and clear tool descriptions.",
                "markdown": "If this project exposes MCP tools, include server files and clear tool descriptions."
              },
              "defaultConfiguration": {
                "level": "note"
              },
              "properties": {
                "category": "mcp_tools",
                "severity": "info",
                "tags": ["agent-readiness", "mcp_tools", "info"]
              }
            },
            {
              "id": "security.missing-agentlighthouseignore",
              "name": "Missing .agentlighthouseignore",
              "shortDescription": {
                "text": "Missing .agentlighthouseignore"
              },
              "fullDescription": {
                "text": "Scans should explicitly exclude generated, private, and secret-bearing paths."
              },
              "help": {
                "text": "Add .agentlighthouseignore with node_modules, build outputs, env files, secrets, and vendor paths.",
                "markdown": "Add .agentlighthouseignore with node_modules, build outputs, env files, secrets, and vendor paths."
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "properties": {
                "category": "security_and_privacy",
                "severity": "medium",
                "tags": ["agent-readiness", "security_and_privacy", "medium"]
              }
            },
            {
              "id": "security.agent-secret-guidance-missing",
              "name": "Instructions do not tell agents how to handle secrets",
              "shortDescription": {
                "text": "Instructions do not tell agents how to handle secrets"
              },
              "fullDescription": {
                "text": "Agent-facing instructions should state how to avoid exposing secrets or private data."
              },
              "help": {
                "text": "Add a security section explaining secret handling and external LLM constraints.",
                "markdown": "Add a security section explaining secret handling and external LLM constraints."
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "properties": {
                "category": "security_and_privacy",
                "severity": "medium",
                "tags": ["agent-readiness", "security_and_privacy", "medium"]
              }
            },
            {
              "id": "freshness.deprecated-or-todo-terms",
              "name": "Docs contain TODO/deprecated-looking terms without migration guidance",
              "shortDescription": {
                "text": "Docs contain TODO/deprecated-looking terms without migration guidance"
              },
              "fullDescription": {
                "text": "Stale markers can confuse agents unless they include replacement guidance."
              },
              "help": {
                "text": "Resolve TODOs or add explicit migration/replacement guidance.",
                "markdown": "Resolve TODOs or add explicit migration/replacement guidance."
              },
              "defaultConfiguration": {
                "level": "note"
              },
              "properties": {
                "category": "freshness_and_consistency",
                "severity": "low",
                "tags": ["agent-readiness", "freshness_and_consistency", "low"]
              }
            },
            {
              "id": "OPENAPI_WEAK_SPEC_DESCRIPTION",
              "name": "OpenAPI spec description is too thin for agents",
              "shortDescription": {
                "text": "OpenAPI spec description is too thin for agents"
              },
              "fullDescription": {
                "text": "The API-level description does not explain product concepts, auth expectations, or common workflows."
              },
              "help": {
                "text": "Add a concise overview of the API domain, common workflows, auth model, and safe usage constraints.",
                "markdown": "Add a concise overview of the API domain, common workflows, auth model, and safe usage constraints.\n\nAgent failure mode: A coding agent may jump straight to endpoints without understanding product nouns, authentication, or workflow ordering.\n\nFix example: Describe the main resources, required authentication, common create/list/update flows, and where to find examples."
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "properties": {
                "category": "api_schema",
                "severity": "medium",
                "tags": ["agent-readiness", "api_schema", "medium"]
              }
            },
            {
              "id": "OPENAPI_AUTH_UNCLEAR",
              "name": "OpenAPI authentication is unclear",
              "shortDescription": {
                "text": "OpenAPI authentication is unclear"
              },
              "fullDescription": {
                "text": "No security scheme or clear authentication guidance was detected."
              },
              "help": {
                "text": "Document the auth scheme, required headers, scopes, and placeholder-safe example credentials.",
                "markdown": "Document the auth scheme, required headers, scopes, and placeholder-safe example credentials.\n\nAgent failure mode: A coding agent may generate client code without the required Authorization header or may invent unsafe credential handling.\n\nFix example: Add an HTTP bearer or API key security scheme and a request example using EXAMPLE_API_KEY."
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "properties": {
                "category": "api_schema",
                "severity": "high",
                "tags": ["agent-readiness", "api_schema", "high"]
              }
            },
            {
              "id": "OPENAPI_SERVER_URL_MISSING",
              "name": "OpenAPI server URL is missing",
              "shortDescription": {
                "text": "OpenAPI server URL is missing"
              },
              "fullDescription": {
                "text": "Agents need a base URL signal to generate usable client examples."
              },
              "help": {
                "text": "Add production and sandbox server URLs, or explain how agents should configure the base URL.",
                "markdown": "Add production and sandbox server URLs, or explain how agents should configure the base URL.\n\nAgent failure mode: A coding agent may invent a base URL or hardcode the wrong host.\n\nFix example: Add servers: [{ url: 'https://api.example.com/v1' }]."
              },
              "defaultConfiguration": {
                "level": "note"
              },
              "properties": {
                "category": "api_schema",
                "severity": "low",
                "tags": ["agent-readiness", "api_schema", "low"]
              }
            },
            {
              "id": "OPENAPI_MISSING_OPERATION_ID",
              "name": "OpenAPI operations have weak or missing operationIds",
              "shortDescription": {
                "text": "OpenAPI operations have weak or missing operationIds"
              },
              "fullDescription": {
                "text": "3 operation(s) need stronger agent-facing API documentation."
              },
              "help": {
                "text": "Give every operation a stable, specific operationId such as createWorkspaceInvite or listCustomerInvoices.",
                "markdown": "Give every operation a stable, specific operationId such as createWorkspaceInvite or listCustomerInvoices.\n\nAgent failure mode: A coding agent may generate confusing client methods or call the wrong endpoint when operation IDs are missing or generic.\n\nFix example: Use verb+noun names that distinguish similar operations, for example revokeApiKey instead of delete."
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "properties": {
                "category": "api_schema",
                "severity": "medium",
                "tags": ["agent-readiness", "api_schema", "medium"]
              }
            },
            {
              "id": "OPENAPI_WEAK_OPERATION_DESCRIPTION",
              "name": "OpenAPI operations have weak descriptions",
              "shortDescription": {
                "text": "OpenAPI operations have weak descriptions"
              },
              "fullDescription": {
                "text": "3 operation(s) need stronger agent-facing API documentation."
              },
              "help": {
                "text": "Add operation descriptions explaining when to use the endpoint, required context, side effects, and recovery behavior.",
                "markdown": "Add operation descriptions explaining when to use the endpoint, required context, side effects, and recovery behavior.\n\nAgent failure mode: A coding agent may choose the wrong operation because summaries alone do not explain intent or preconditions.\n\nFix example: Add descriptions that mention required IDs, auth scope, side effects, and common failure handling."
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "properties": {
                "category": "api_schema",
                "severity": "medium",
                "tags": ["agent-readiness", "api_schema", "medium"]
              }
            },
            {
              "id": "OPENAPI_MISSING_REQUEST_EXAMPLE",
              "name": "Write operations lack request examples",
              "shortDescription": {
                "text": "Write operations lack request examples"
              },
              "fullDescription": {
                "text": "1 operation(s) need stronger agent-facing API documentation."
              },
              "help": {
                "text": "Add request examples for create/update operations using realistic placeholder values.",
                "markdown": "Add request examples for create/update operations using realistic placeholder values.\n\nAgent failure mode: A coding agent may send malformed payloads or omit required fields because no concrete request shape is shown.\n\nFix example: Add an example body with workspace_id, customer_id, and idempotency_key where relevant."
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "properties": {
                "category": "api_schema",
                "severity": "medium",
                "tags": ["agent-readiness", "api_schema", "medium"]
              }
            },
            {
              "id": "OPENAPI_MISSING_RESPONSE_EXAMPLE",
              "name": "Operations lack response examples",
              "shortDescription": {
                "text": "Operations lack response examples"
              },
              "fullDescription": {
                "text": "3 operation(s) need stronger agent-facing API documentation."
              },
              "help": {
                "text": "Add response examples for successful and important error cases.",
                "markdown": "Add response examples for successful and important error cases.\n\nAgent failure mode: A coding agent may write incorrect parsing code because expected response shapes are not exemplified.\n\nFix example: Add 200/201 response examples with IDs, timestamps, pagination cursors, and nested objects."
              },
              "defaultConfiguration": {
                "level": "note"
              },
              "properties": {
                "category": "api_schema",
                "severity": "low",
                "tags": ["agent-readiness", "api_schema", "low"]
              }
            },
            {
              "id": "OPENAPI_MISSING_ERROR_RESPONSES",
              "name": "Operations lack common error responses",
              "shortDescription": {
                "text": "Operations lack common error responses"
              },
              "fullDescription": {
                "text": "3 operation(s) need stronger agent-facing API documentation."
              },
              "help": {
                "text": "Document likely 400/401/403/404/409/429/500 responses and how callers should recover.",
                "markdown": "Document likely 400/401/403/404/409/429/500 responses and how callers should recover.\n\nAgent failure mode: A coding agent may generate happy-path-only integrations with no auth, retry, or validation recovery.\n\nFix example: Add 401, 404, 409, and 429 responses with short descriptions and example error payloads."
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "properties": {
                "category": "api_schema",
                "severity": "medium",
                "tags": ["agent-readiness", "api_schema", "medium"]
              }
            },
            {
              "id": "OPENAPI_AMBIGUOUS_OPERATION_NAME",
              "name": "OpenAPI operation names are ambiguous",
              "shortDescription": {
                "text": "OpenAPI operation names are ambiguous"
              },
              "fullDescription": {
                "text": "3 operation(s) need stronger agent-facing API documentation."
              },
              "help": {
                "text": "Rename generic operationIds so similar endpoints are distinguishable to code generators and agents.",
                "markdown": "Rename generic operationIds so similar endpoints are distinguishable to code generators and agents.\n\nAgent failure mode: A coding agent may map multiple endpoints to vague client methods such as run, query, or update.\n\nFix example: Prefer syncCatalog, searchDocuments, or updateWorkspaceMember over generic names."
              },
              "defaultConfiguration": {
                "level": "note"
              },
              "properties": {
                "category": "api_schema",
                "severity": "low",
                "tags": ["agent-readiness", "api_schema", "low"]
              }
            },
            {
              "id": "OPENAPI_DESTRUCTIVE_OPERATION_UNMARKED",
              "name": "Destructive API operations are not clearly marked",
              "shortDescription": {
                "text": "Destructive API operations are not clearly marked"
              },
              "fullDescription": {
                "text": "1 operation(s) need stronger agent-facing API documentation."
              },
              "help": {
                "text": "Mark destructive operations with permission, confirmation, irreversibility, and recovery guidance.",
