{
  "name": "agentlighthouse",
  "version": "0.1.0",
  "private": true,
  "description": "Lighthouse for AI agents: scan repositories, docs, APIs, and workflows for agent-readiness.",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "type": "module",
  "dependencies": {
    "@agentlighthouse/core": "workspace:*"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @agentlighthouse/web dev",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "typecheck": "pnpm -r typecheck",
    "validate:realworld": "tsx scripts/validate-realworld.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "prettier": "^3.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  }
}
