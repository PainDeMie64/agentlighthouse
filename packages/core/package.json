{
  "name": "@agentlighthouse/core",
  "version": "0.1.0",
  "description": "Core scanner, schemas, scoring, and generators for AgentLighthouse.",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist",
    "src",
    "!src/__tests__",
    "!dist/__tests__",
    "package.json",
    "README.md"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "yaml": "^2.9.0",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  }
}
