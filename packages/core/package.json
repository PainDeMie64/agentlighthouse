{
  "name": "@agentlighthouse/core",
  "version": "0.1.0-alpha.1",
  "description": "Core scanner, schemas, scoring, and generators for AgentLighthouse.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PainDeMie64/agentlighthouse.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/PainDeMie64/agentlighthouse#readme",
  "bugs": {
    "url": "https://github.com/PainDeMie64/agentlighthouse/issues"
  },
  "keywords": [
    "agent-readiness",
    "ai-agents",
    "openapi",
    "mcp",
    "ci",
    "sarif"
  ],
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "!dist/__tests__",
    "!dist/.tsbuildinfo",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "yaml": "^2.9.0",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  }
}
